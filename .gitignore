node_modules/
dist/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# ENVIRONMENT VARIABLES (CRITICAL!)
# ============================================================
# Не пушим реальные .env файлы с паролями!
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test

# Все .env файлы в папках сервисов
backend/*/.env
backend/*/.env.local
backend/*/.env.*.local

# Фронтенд .env
frontend/.env
frontend/.env.local
frontend/.env.*.local

# НО .env.example должны быть в репозитории!
!*.env.example
!.env.example

