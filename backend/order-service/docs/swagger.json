                    "application/json"
                ],
                "tags": [
                    "orders"
                ],
                "summary": "Получение заказов покупателя",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID покупателя",
                        "name": "customer_id",
                        "in": "query",
                        "required": true
                    }
